# Development workflow for Wrenflow Flutter app

# Generate Dart bindings from Rust signals
gen:
    rinf gen

# Watch mode: regenerate bindings on Rust signal changes
watch:
    rinf gen --watch

# Run the app on macOS (debug)
run: gen
    flutter run -d macos

# Build macOS debug
build: gen
    flutter build macos --debug

# Build macOS release
release: gen
    flutter build macos --release

# Run flutter analyze
analyze:
    flutter analyze

# Run flutter tests
test:
    flutter test

# Run Rust tests (domain + core)
test-rust:
    cd ../core && cargo test -p wrenflow-domain -p wrenflow-core

# Check Rust hub compiles
check-rust:
    cd native/hub && cargo check

# Clean all build artifacts
clean:
    flutter clean
    cd native/hub && cargo clean

# Install all dependencies (mise + flutter + pods)
setup:
    mise install
    flutter pub get
    rinf gen
